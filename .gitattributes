# =============================================================================
# .gitattributes
# Normalização de fim de linha: LF canônico no repositório
# =============================================================================

# Regra base: todos os arquivos de texto → LF
* text=auto eol=lf

# --- Código ---
*.py    text eol=lf
*.R     text eol=lf
*.r     text eol=lf
*.Rmd   text eol=lf
*.qmd   text eol=lf
*.sql   text eol=lf
*.sh    text eol=lf
*.ps1   text eol=lf
*.psm1  text eol=lf

# --- Dados e markup ---
*.csv   text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf

# --- Binários — sem conversão ---
*.png   binary
*.jpg   binary
*.jpeg  binary
*.pdf   binary
*.xlsx  binary
*.xls   binary
*.docx  binary
*.doc   binary
*.zip   binary
*.gz    binary
*.parquet binary
*.rds   binary
*.RData binary
*.pkl   binary
*.db    binary
*.sqlite binary